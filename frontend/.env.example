# Where the GitPulse API lives.
#
# Copy to .env.local for local development.
#
# NEXT_PUBLIC_* is inlined into the client bundle at BUILD time — it is not read
# at runtime. Changing it on Vercel therefore requires a redeploy, not a restart.

# Local backend (docker compose, or `uvicorn app.main:app`)
#NEXT_PUBLIC_API_BASE=http://localhost:8000

# Deployed backend — set this one in the Vercel project's Environment Variables:
NEXT_PUBLIC_API_BASE=https://gitpulse-api-tznz.onrender.com
